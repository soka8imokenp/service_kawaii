WEBHOOK_URL=https://your-domain.com/webhook/telegram
GEMINI_API_KEY=your-gemini-key-here
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True